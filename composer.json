{
    "name": "adtention/nova-datepicker-filter",
    "description": "A Laravel Nova date field built as a thin wrapper around vuepic/vue-datepicker.",
    "keywords": [
        "laravel",
        "laravel-nova",
        "laravel-nova-filter",
        "datepicker"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/nova": "^5.0",
        "laravel/nova-devtool": "^1.7",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^11.0|^12.0|^13.0"
    },
    "repositories": [
        { "type": "composer", "url": "https://nova.laravel.com" }
    ],
    "autoload": {
        "psr-4": {
            "Adtention\\DatepickerFilter\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Adtention\\DatepickerFilter\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Adtention\\DatepickerFilter\\FilterServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
